# NOTE: syntactically valid but semantically nonsensical — parser stress test.

include "core.zing"

function mix (a: stereo number, b: stereo number) -> (out: stereo number)
	out = a + b

function gain (signal: stereo number, amount: mono number) -> (out: stereo number)
	out = signal * amount

module envelope (signal: dynamic stereo number, atk: static mono number, rel: static mono number) -> (out: dynamic stereo number)
	out = signal * envValue
	envValue = delay(0.0, 100)

# Function with no inputs, no outputs
function noop () -> ()

# Function with bool type annotation
function isGate () -> (result: mono bool)
	result = true

# Module with generic width
module genericProc (in: generic number) -> (out: generic number)
	out = in * 2.0

# Module with buffer type annotation
module bufProc (data: static generic buffer, idx: static mono number) -> (out: dynamic mono number)
	out = data[idx]

# Module with multiple MIDI params (MidiParam* comes before Id in grammar)
global module midi1::midi2::midiDriven (input: dynamic stereo number) -> (out: dynamic stereo number)
	out = input
