{
    "name": "jingler-syntax",
    "displayName": "Jingler",
    "publisher": "askeksa",
    "description": "Syntax highlighting for the Zing language used in Jingler",
    "icon": "",
    "repository": "https://github.com/askeksa/jingler-syntax",
    "version": "2.0.0",
    "engines": {
        "vscode": "^1.75.0"
    },
    "activationEvents": [
        "onLanguage:zing"
    ],
    "main": "./out/extension.js",
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "lint": "eslint \"src/**/*.ts\"",
        "watch": "tsc -watch -p ./",
        "pretest": "npm run compile",
        "test": "node out/test/runTest.js"
    },
    "devDependencies": {
        "@types/mocha": "^10.0.10",
        "@types/node": "^18",
        "@types/vscode": "^1.75.0",
        "@typescript-eslint/eslint-plugin": "^7.18.0",
        "@typescript-eslint/parser": "^7.18.0",
        "@vscode/test-electron": "^2.3.0",
        "eslint": "^8.26.0",
        "glob": "^8.1.0",
        "mocha": "^10.2.0",
        "typescript": "^5.5.2"
    },
    "categories": [
        "Programming Languages"
    ],
    "contributes": {
        "languages": [
            {
                "id": "zing",
                "aliases": [
                    "Zing"
                ],
                "extensions": [
                    ".zing"
                ],
                "configuration": "./language-configuration.json"
            }
        ],
        "semanticTokenScopes": [
            {
                "language": "zing",
                "scopes": {
                    "zingToplevel": [
                        "storage.type.zing.toplevel"
                    ],
                    "zingToplevelModifier": [
                        "storage.modifier.zing.toplevel"
                    ],
                    "zingScope": [
                        "entity.name.type.zing.scope"
                    ],
                    "zingWidth": [
                        "entity.name.type.zing.width"
                    ],
                    "zingType": [
                        "entity.name.type.zing.type"
                    ],
                    "zingControl": [
                        "keyword.control.zing"
                    ],
                    "supportFunction": [
                        "support.function"
                    ]
                }
            }
        ]
    },
    "dependencies": {
        "@vscode/vsce": "^2.18.0"
    },
    "allowScripts": {
        "@vscode/vsce-sign@2.0.9": true,
        "keytar@7.9.0": true
    }
}
